# Environment
ENVIRONMENT=development  # or: production

# Database
# For local dev without Docker: use localhost
# For Docker Compose: change localhost to db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/decision_loop

# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# Fernet encryption key for stored API keys — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Frontend origin for CORS (no trailing slash)
FRONTEND_URL=http://localhost:3000
